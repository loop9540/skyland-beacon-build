---
type IconNode = [string, Record<string, string | number>][];

interface Props {
  icon: IconNode;
  class?: string;
  id?: string;
  "aria-label"?: string;
}

const { icon, class: className, "aria-label": ariaLabel, ...attrs } = Astro.props;
---

<svg
  {...attrs}
  class={className}
  xmlns="http://www.w3.org/2000/svg"
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={ariaLabel ? undefined : "true"}
  aria-label={ariaLabel}
>
  {
    icon.map(([tag, childAttrs]) => {
      const Tag = tag;
      return <Tag {...childAttrs} />;
    })
  }
</svg>
