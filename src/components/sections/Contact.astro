---
import { Clock, Mail, MapPin, Phone } from "lucide";
import LucideIcon from "@/components/LucideIcon.astro";
import { SITE } from "../../lib/site";

const rows = [
  { icon: Phone, label: "Phone", value: SITE.phone, href: SITE.phoneHref },
  { icon: Mail, label: "Email", value: SITE.email, href: `mailto:${SITE.email}` },
  { icon: MapPin, label: "Location", value: SITE.location, href: null },
  { icon: Clock, label: "Hours", value: "Calls answered daily", href: null },
];
---

<section class="pt-32 md:pt-40 pb-24 md:pb-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="reveal">
      <div class="eyebrow text-moss">Contact</div>
      <h2
        class="mt-4 font-display text-5xl md:text-7xl font-light leading-[1.02] text-balance max-w-4xl"
      >
        Call us. We're real people on the other end.
      </h2>
      <p class="mt-6 max-w-2xl text-lg text-foreground/80 text-pretty">
        The fastest way to talk about whether Skyland Ranch is right for you — or for someone you love
        — is a phone call. No forms, no automated systems.
      </p>
    </div>

    <div class="mt-16 grid gap-12 md:grid-cols-2 items-start">
      <div class="reveal">
        <div class="rounded-3xl bg-gradient-dawn p-10 md:p-12 text-mist shadow-lift">
          <div class="eyebrow text-sage">Best way to reach us</div>
          <h3
            class="mt-3 font-display text-4xl md:text-5xl leading-tight font-light text-balance"
          >
            Pick up the phone.
          </h3>
          <a
            href={SITE.phoneHref}
            class="mt-8 inline-flex items-center gap-3 rounded-full bg-mist text-forest px-7 py-4 text-lg font-medium hover:-translate-y-0.5 transition-transform"
          >
            <LucideIcon icon={Phone} class="h-5 w-5" /> {SITE.phone}
          </a>
          <p class="mt-6 text-mist/85 text-pretty">
            Calls are private. We listen first, then answer questions. There is never any pressure.
          </p>
        </div>
      </div>

      <div class="reveal" style="--reveal-delay:150ms">
        <div class="rounded-2xl bg-card border border-border/60 p-10 shadow-soft">
          <div class="eyebrow text-moss">Reach the ranch</div>
          <ul class="mt-6 space-y-6">
            {
              rows.map((r) => {
                const inner = (
                  <div class="flex items-start gap-4">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-forest/10 text-forest">
                      <LucideIcon icon={r.icon} class="h-4 w-4" />
                    </div>
                    <div>
                      <div class="text-[0.7rem] uppercase tracking-[0.2em] text-muted-foreground">
                        {r.label}
                      </div>
                      <div class="mt-0.5 text-foreground font-medium">{r.value}</div>
                    </div>
                  </div>
                );
                return (
                  <li>
                    {r.href ? (
                      <a href={r.href} class="block hover:opacity-80 transition-opacity">
                        {inner}
                      </a>
                    ) : (
                      inner
                    )}
                  </li>
                );
              })
            }
          </ul>
          <div class="hairline mt-10"></div>
          <p class="mt-6 text-sm text-muted-foreground text-pretty">
            If you're calling on behalf of a loved one — a son, a brother, a friend — that's a
            conversation we have often, and we welcome it.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
