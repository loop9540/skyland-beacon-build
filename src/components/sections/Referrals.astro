---
import { Check, Mail, Phone } from "lucide";
import LucideIcon from "@/components/LucideIcon.astro";
import { SITE, url } from "../../lib/site";

const offers = [
  "Men only, ages 18+, stable and ready for sober living",
  "Drug- and alcohol-free residence in the Cascade foothills",
  "Structured days with ranch work, horse care, and peer community",
  "Open-ended length of stay — most residents stay 6 to 18 months",
  "45 minutes from Seattle; we coordinate transport from SeaTac",
];
---

<section class="bg-secondary/40 border-y border-border/60 py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="reveal max-w-3xl">
      <div class="eyebrow text-moss">For families and providers</div>
      <h2 class="mt-4 font-display text-4xl md:text-6xl font-light leading-[1.04] text-balance">
        A sober living next step.
      </h2>
      <p class="mt-6 text-lg text-foreground/80 text-pretty">
        If you're helping someone look for a long-term, drug- and alcohol-free place to live after
        a short-term program, a hospital stay, or another transition, we'd like to talk. The fastest
        way is a single phone call — no forms, no portals.
      </p>
    </div>

    <div class="mt-16 grid gap-12 md:grid-cols-2 items-start">
      <div class="reveal">
        <div class="rounded-3xl bg-gradient-dawn p-10 md:p-12 text-mist shadow-lift">
          <div class="eyebrow text-sage">What we offer</div>
          <h3 class="mt-3 font-display text-3xl md:text-4xl leading-tight font-light text-balance">
            Long-term sober living on a working ranch.
          </h3>
          <ul class="mt-8 space-y-4 text-mist/90">
            {
              offers.map((line) => (
                <li class="flex items-start gap-3">
                  <LucideIcon icon={Check} class="mt-1 h-4 w-4 shrink-0 text-sage" />
                  <span class="text-pretty">{line}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="reveal" style="--reveal-delay:150ms">
        <div class="rounded-2xl bg-card border border-border/60 p-8 md:p-10 shadow-soft">
          <div class="eyebrow text-moss">Start a conversation</div>
          <h3 class="mt-3 font-display text-3xl leading-tight text-foreground">
            One call, and we'll take it from there.
          </h3>
          <p class="mt-4 text-foreground/75 text-pretty">
            We've kept this deliberately simple: no intake forms, no application portal. Call or email and
            we'll talk through whether the ranch may be a fit. Please <strong>do not send medical records,
            treatment records, or PHI</strong> by email — a short description of the housing need is enough,
            and we'll follow up by phone.
          </p>

          <div class="mt-8 space-y-4">
            <a
              href={SITE.phoneHref}
              class="flex items-center gap-4 rounded-xl border border-border/70 bg-background px-5 py-4 hover:border-forest/40 transition-colors"
            >
              <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-forest text-mist">
                <LucideIcon icon={Phone} class="h-5 w-5" />
              </span>
              <span>
                <span class="block text-[0.7rem] uppercase tracking-[0.2em] text-muted-foreground">Call us</span>
                <span class="mt-0.5 block text-lg font-medium text-foreground">{SITE.phone}</span>
              </span>
            </a>
            <a
              href={`mailto:${SITE.email}?subject=Sober%20living%20inquiry`}
              class="flex items-center gap-4 rounded-xl border border-border/70 bg-background px-5 py-4 hover:border-forest/40 transition-colors"
            >
              <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-forest text-mist">
                <LucideIcon icon={Mail} class="h-5 w-5" />
              </span>
              <span class="min-w-0">
                <span class="block text-[0.7rem] uppercase tracking-[0.2em] text-muted-foreground">Email us</span>
                <span class="mt-0.5 block text-lg font-medium text-foreground break-all">{SITE.email}</span>
              </span>
            </a>
          </div>

          <p class="mt-6 text-xs text-muted-foreground text-pretty">
            Calls are answered daily. Skyland Ranch is a sober living residence, not a detox, medical,
            counseling, or behavioral health treatment provider. Read our{" "}
            <a href={url("/privacy")} class="text-forest underline underline-offset-4 hover:text-moss">
              privacy and non-clinical notice
            </a>.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
