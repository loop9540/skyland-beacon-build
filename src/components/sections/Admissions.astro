---
import PageHeader from "../PageHeader.astro";
import { SITE, sectionHref } from "../../lib/site";
import { ArrowRight, Check, Play, MapPin } from "@lucide/astro";
import valleyImg from "../../assets/admissions-valley.jpg";

const STEPS = [
  { title: "Call us", body: "Speak with someone who has done this conversation many times. We'll listen first, then answer questions." },
  { title: "Visit, if you can", body: "When it makes sense, come see the ranch. Walk the property, meet the horses, get a feel for the place." },
  { title: "Arrive", body: "Move in when you're ready. The community will help you find your footing in the first days." },
];

const FITS = [
  "Wants a drug and alcohol-free environment to live in, short or long term.",
  "Has tried other treatment and is looking for something with more time and more ground beneath it.",
  "Is open to honest work, ranch life, and being part of a community of men in recovery.",
  "Arrives with a dual diagnosis — substance use alongside depression, anxiety, or trauma — and is open to community-based support with clinical connections.",
  "Is medically and physically able to participate in ranch chores and daily life.",
];
---

<PageHeader
  as="h2"
  eyebrow="Admissions"
  title="The first call<br /> is the hardest one."
  intro="There's no form to fill out before you can talk to a real person. Pick up the phone, and we'll walk through it together — honestly, confidentially, with no pressure."
  image={valleyImg}
  imageAlt="A green pasture at the ranch with the Cascade foothills rising behind"
  light
/>

<section class="py-24 md:py-32">
  <div class="mx-auto max-w-5xl px-6">
    <div class="reveal">
      <div class="eyebrow text-moss">How it works</div>
      <h3 class="mt-4 font-display text-4xl md:text-5xl leading-tight text-balance">
        Three steps. No paperwork to begin.
      </h3>
    </div>
    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {
        STEPS.map((s, i) => (
          <div class="reveal" style={`--reveal-delay:${i * 100}ms`}>
            <div class="relative h-full rounded-2xl bg-card border border-border/60 p-8 shadow-soft">
              <div class="font-display text-7xl text-sage leading-none">0{i + 1}</div>
              <h4 class="mt-4 font-display text-xl text-foreground">{s.title}</h4>
              <p class="mt-3 text-foreground/70 text-pretty">{s.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Virtual tour -->
<section class="bg-forest text-mist py-24 md:py-32 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-10 grid gap-12 md:grid-cols-2 items-center">
    <div class="reveal">
      <div class="eyebrow text-sage">Can't visit yet?</div>
      <h3 class="mt-4 font-display text-4xl md:text-5xl leading-tight font-light text-balance">
        Take a virtual look at the ranch.
      </h3>
      <p class="mt-6 text-mist/85 text-lg text-pretty">
        Skyland sits on more than {SITE.acres} acres in the Cascade foothills — pasture, second-growth
        forest, and quiet trails along the Skykomish River, with the mountains on every side. If you
        can't make the drive yet, watch the film and see the place for yourself.
      </p>
      <button
        type="button"
        data-video-open
        data-embed={SITE.filmEmbed}
        class="mt-8 inline-flex items-center gap-3 rounded-full bg-dawn text-accent-foreground px-7 py-4 text-base font-medium shadow-lift hover:-translate-y-0.5 transition-transform"
      >
        <Play class="h-5 w-5 fill-current" /> Watch the film
      </button>
      <p class="mt-5 inline-flex items-center gap-2 text-sm text-mist/70">
        <MapPin class="h-4 w-4" /> {SITE.location}
      </p>
    </div>
    <div class="reveal" style="--reveal-delay:150ms">
      <button
        type="button"
        data-video-open
        data-embed={SITE.filmEmbed}
        aria-label="Play the Skyland Ranch film"
        class="group relative block w-full overflow-hidden rounded-2xl border-2 border-mist/30 shadow-lift hover:-translate-y-1 transition-transform"
      >
        <img
          src={`https://img.youtube.com/vi/${SITE.youtubeId}/maxresdefault.jpg`}
          alt="A look across the Skyland Ranch property"
          width="1280"
          height="720"
          loading="lazy"
          class="h-auto w-full object-cover aspect-video"
        />
        <span class="absolute inset-0 flex items-center justify-center bg-forest/25 group-hover:bg-forest/35 transition-colors">
          <span class="flex h-16 w-16 items-center justify-center rounded-full bg-mist/95 text-forest shadow-lift group-hover:scale-110 transition-transform">
            <Play class="h-7 w-7 fill-current ml-1" />
          </span>
        </span>
      </button>
    </div>
  </div>
</section>

<section class="bg-secondary/40 border-y border-border/60 py-24 md:py-32">
  <div class="mx-auto max-w-5xl px-6 grid gap-12 md:grid-cols-2">
    <div class="reveal">
      <div class="eyebrow text-moss">Who we serve</div>
      <h3 class="mt-4 font-display text-3xl md:text-4xl leading-tight text-balance">
        The ranch is a good fit for a man who:
      </h3>
      <p class="mt-5 text-foreground/70 text-pretty">
        Many of the men who come to us arrive with a dual diagnosis — addiction alongside depression,
        anxiety, or trauma. The ranch supports them through community, structure, and our connections
        to local clinical care.
      </p>
    </div>
    <div class="reveal" style="--reveal-delay:100ms">
      <ul class="space-y-4">
        {
          FITS.map((f) => (
            <li class="flex gap-4">
              <div class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-forest text-mist">
                <Check class="h-3.5 w-3.5" />
              </div>
              <span class="text-foreground/80 text-pretty">{f}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<section class="bg-forest text-mist py-24 md:py-32">
  <div class="mx-auto max-w-4xl px-6 text-center">
    <div class="reveal">
      <div class="eyebrow text-sage">Cost & accessibility</div>
      <h3 class="mt-4 font-display text-3xl md:text-4xl leading-tight text-balance font-light">
        We work with families to make this accessible.
      </h3>
      <p class="mt-6 text-mist/85 text-lg text-pretty max-w-2xl mx-auto">
        The ranch operates on a sliding scale based on circumstance. We encourage you to call and talk
        through what might work — no pressure, no obligation.
      </p>
      <a
        href={sectionHref("contact")}
        class="mt-8 inline-flex items-center gap-2 text-dawn border-b border-dawn/40 pb-1 hover:border-dawn transition-colors"
      >
        Talk to us about fees <ArrowRight class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>

<section class="py-24 md:py-32">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <div class="reveal">
      <div class="eyebrow text-moss">Ready when you are</div>
      <h3 class="mt-4 font-display text-4xl md:text-5xl leading-tight text-balance">
        Make the call.<br />We'll take it from there.
      </h3>
      <p class="mt-6 text-foreground/70 text-pretty">
        Calls are confidential, and there's no obligation. When you're ready, here's how to reach us.
      </p>
      <a
        href={sectionHref("contact")}
        class="mt-8 inline-flex items-center gap-2 text-forest border-b border-forest/40 pb-1 hover:border-forest transition-colors"
      >
        Get in touch <ArrowRight class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
