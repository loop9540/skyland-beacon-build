---
import { Image } from "astro:assets";
import { Menu, Phone } from "@lucide/astro";
import { NAV, SITE, url, sectionHref } from "../lib/site";
import logo from "../assets/skyland-logo.png";
---

<header id="site-header" class="fixed top-0 inset-x-0 z-50 transition-all duration-500">
  <div class="mx-auto max-w-7xl px-6 lg:px-10 flex items-center justify-between h-20 md:h-24">
    <a href={url("/")} class="group flex items-center" aria-label="Skyland Ranch home">
      <Image
        src={logo}
        alt="Skyland Ranch — men's drug and alcohol therapeutic residence program"
        class="h-10 md:h-12 w-auto transition-transform duration-500 group-hover:-translate-y-0.5"
        widths={[200, 300]}
        sizes="160px"
        loading="eager"
      />
    </a>

    <nav class="hidden lg:flex items-center gap-1">
      {
        NAV.map((item) =>
          "id" in item ? (
            <a
              href={sectionHref(item.id)}
              data-spy={item.id}
              class="navlink px-4 py-2 text-sm text-foreground/80 hover:text-forest transition-colors"
            >
              {item.label}
            </a>
          ) : (
            <a
              href={url(item.href)}
              class="navlink px-4 py-2 text-sm text-foreground/80 hover:text-forest transition-colors"
            >
              {item.label}
            </a>
          ),
        )
      }
    </nav>

    <div class="hidden md:flex items-center">
      <a
        href={SITE.phoneHref}
        class="inline-flex items-center gap-2 rounded-full bg-forest text-primary-foreground pl-4 pr-5 py-2.5 text-sm font-medium shadow-soft hover:bg-moss transition-all hover:shadow-lift"
      >
        <Phone class="h-4 w-4" />
        {SITE.phone}
      </a>
    </div>

    <button
      id="menu-toggle"
      type="button"
      class="lg:hidden p-2 -mr-2 text-foreground"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <Menu id="menu-icon-open" class="h-6 w-6" />
    </button>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden bg-background/95 backdrop-blur-xl border-t border-border/60 animate-reveal"
    hidden
  >
    <div class="px-6 py-6 flex flex-col gap-1">
      {
        NAV.map((item) =>
          "id" in item ? (
            <a
              href={sectionHref(item.id)}
              class="py-3 text-lg font-display text-foreground/80 hover:text-forest transition-colors"
            >
              {item.label}
            </a>
          ) : (
            <a
              href={url(item.href)}
              class="py-3 text-lg font-display text-foreground/80 hover:text-forest transition-colors"
            >
              {item.label}
            </a>
          ),
        )
      }
      <a
        href={SITE.phoneHref}
        class="mt-4 inline-flex items-center justify-center gap-2 rounded-full bg-forest text-primary-foreground px-5 py-3 text-base font-medium"
      >
        <Phone class="h-4 w-4" />
        Call {SITE.phone}
      </a>
    </div>
  </div>
</header>

<style>
  #site-header.is-scrolled {
    background-color: color-mix(in oklab, var(--background) 85%, transparent);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid color-mix(in oklab, var(--border) 60%, transparent);
  }
  .navlink.is-active {
    color: var(--forest);
    font-weight: 500;
  }
</style>
