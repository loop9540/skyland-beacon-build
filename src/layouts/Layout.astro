---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { url, SITE } from "../lib/site";

interface Props {
  title: string;
  description: string;
  /** Path of this page (e.g. "/" or "/referrals") for the canonical/og:url. */
  path?: string;
  /** Render the organization JSON-LD (home page only). */
  organizationSchema?: boolean;
}

const {
  title,
  description,
  path = "/",
  organizationSchema = false,
} = Astro.props;

const site = Astro.site ?? new URL("https://skylandranch.org");
// Canonicals/og:url use a trailing slash to match what GitHub Pages serves.
const pagePath = path.endsWith("/") ? path : `${path}/`;
const canonical = new URL(url(pagePath), site).href;
const ogImage = new URL(url("/media/og-image.jpg"), site).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Skyland Ranch",
  description:
    "A nonprofit working horse ranch offering long-term sober living for men near Seattle, Washington.",
  url: canonical,
  telephone: SITE.phoneHref.replace("tel:", ""),
  email: SITE.email,
  image: ogImage,
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Gold Bar",
    addressRegion: "WA",
    addressCountry: "US",
  },
  foundingDate: "1986",
  founder: {
    "@type": "Person",
    name: "Mr. Pitkin",
    alternateName: "Pa",
    description:
      "A former San Diego attorney and judge who founded Skyland Ranch to offer men a sober living home shaped by ranch work, community, and the company of horses.",
  },
  areaServed: "Seattle, WA",
};
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={url("/favicon.png")} />
    <link rel="apple-touch-icon" href={url("/favicon.png")} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href={url("/sitemap-index.xml")} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Skyland Ranch" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Skyland Ranch" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      organizationSchema && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />

    <script>
      import "../scripts/site.ts";
    </script>
  </body>
</html>
