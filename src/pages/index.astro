---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections/Hero.astro";
import Quote from "../components/sections/Quote.astro";
import About from "../components/sections/About.astro";
import Program from "../components/sections/Program.astro";
import Residence from "../components/sections/Residence.astro";
import Admissions from "../components/sections/Admissions.astro";
import Contact from "../components/sections/Contact.astro";
---

<Layout
  title="Skyland Ranch — Sober Living for Men Near Seattle, WA"
  description="A working horse ranch offering long-term drug and alcohol-free recovery for men in the Cascade foothills near Seattle. Equine therapy, dignity, hope — since 1986."
  path="/"
  organizationSchema
>
  <Hero />
  <Quote />
  <div id="about"><About /></div>
  <div id="program"><Program /></div>
  <div id="residence"><Residence /></div>
  <div id="admissions"><Admissions /></div>
  <div id="contact"><Contact /></div>
</Layout>
