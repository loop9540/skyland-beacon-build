---
import Layout from "../layouts/Layout.astro";
import { url } from "../lib/site";
---

<Layout
  title="Page not found — Skyland Ranch"
  description="The page you're looking for doesn't exist or has been moved."
  path="/404"
>
  <section class="flex min-h-[70vh] items-center justify-center px-6 pt-32 pb-24">
    <div class="max-w-md text-center">
      <div class="font-display text-7xl font-light text-forest">404</div>
      <h1 class="mt-4 font-display text-2xl text-foreground">Page not found</h1>
      <p class="mt-2 text-foreground/70 text-pretty">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href={url("/")}
        class="mt-8 inline-flex items-center justify-center rounded-full bg-forest text-primary-foreground px-6 py-3 text-sm font-medium hover:bg-moss transition-colors"
      >
        Go home
      </a>
    </div>
  </section>
</Layout>
