# Copy to .env and fill in. Do NOT commit .env (it is gitignored).
# Public (safe to expose; baked into the client bundle, protected by Supabase RLS):
VITE_SUPABASE_URL="https://<project>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-publishable-key>"
VITE_SUPABASE_PROJECT_ID="<project-id>"
SUPABASE_URL="https://<project>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<anon-publishable-key>"
SUPABASE_PROJECT_ID="<project-id>"

# SECRET — server-only, used by the referrals server functions (src/integrations/supabase/client.server.ts).
# Set this in Vercel project env vars, NEVER in a committed file.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
